{
    "$schema": "https://json.schemastore.org/tsconfig",
    "compilerOptions": {
        "module": "node16",
        "moduleResolution": "node16",
        "outDir": "dist",
        "allowJs": true,
        "esModuleInterop": true,
        "lib": ["es2021"],
        "target": "es2021",

        // TODO?: "paths": { "@/*": ["./*"] },

        // TODO?: "strict": true,
        "strictNullChecks": true, // TODO?: can be removed once "strict" is enabled
        "noUncheckedSideEffectImports": true,
        "skipLibCheck": true
    },

    "include": [ "./**/*.ts" ],
}
